{
  "manifest_version": 3,
  "name": "Better Coretax",
  "version": "1.0.0",
  "description": "Helper for Coretax DJP",
  "background": {
    "scripts": ["background/background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://coretaxdjp.pajak.go.id/*"],
      "js": ["content/main.js"],
      "css": ["styles/injected.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/scraper.js"],
      "matches": ["https://coretaxdjp.pajak.go.id/*"]
    }
  ],
  "host_permissions": [
    "https://coretaxdjp.pajak.go.id/*"
  ],
  "permissions": [
    "activeTab",
    "storage",
    "tabs"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "better-coretax-ext-v1@arism.me"
    }
  }
}
