{
  "name": "better-coretax",
  "version": "1.0.0",
  "description": "Better Coretax DJP Firefox Extension",
  "main": "build.js",
  "scripts": {
    "build": "node build.js",
    "build:chrome": "node build.js --browser=chrome",
    "build:firefox": "node build.js --browser=firefox",
    "watch": "node build.js --watch",
    "package:chrome": "node build.js --browser=chrome && node package.js --browser=chrome",
    "package:firefox": "node build.js --browser=firefox && node package.js --browser=firefox",
    "package": "npm run package:chrome && npm run package:firefox",
    "package:source": "node package-source.js"
  },
  "keywords": [
    "firefox",
    "extension",
    "coretax"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/firefox-webext-browser": "^120.0.4",
    "archiver": "^7.0.1",
    "esbuild": "^0.20.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "xlsx": "^0.18.5"
  }
}
